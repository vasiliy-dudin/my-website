---
layout: _base.njk
---

{% macro headerInfoBlock(blockTitle, blockText) %}
	<div class="project-header__info{{ ' --wide' if blockText | length > 60 }}">
		<h3 class="project-header__info__title">{{ blockTitle }}</h3>
		<div class="project-header__info-text">{{ blockText | markdown | safe }}</div>
	</div>
{% endmacro %}

{% macro neighbours(where) %}
	{# Neighbours #}
	{% set collection = collections.allProjects %}
	{% set previousPage = collection | getPreviousCollectionItem %}
	{% set nextPage = collection | getNextCollectionItem %}
	{% if previousPage or nextPage %}
		<div class="project-neighbours">
			{% if previousPage %}
				<a class="project-neighbours__lnk --prev" href="{{ previousPage.url }}" title="{{ previousPage.data.title }}" onclick="plausible('Project neighbours', { props: { page: window.location.pathname, direction: 'prev' }})">
					{% include "../assets/arrow-neighbours.svg" %}
				</a>
			{% endif %}
			{% if nextPage %}
				<a class="project-neighbours__lnk --next" href="{{ nextPage.url }}" title="{{ nextPage.data.title }}" onclick="plausible('Project neighbours', { props: { page: window.location.pathname, direction: 'next' }})">
					{% include "../assets/arrow-neighbours.svg" %}
				</a>
			{% endif %}
		</div>
	{% endif %}
{% endmacro %}


<div class="--project">
		<div class="project-col-2">
			
			<div class="project-nav">
				<a href="#overview " onclick="plausible('Project navigation', { props: { page: window.location.pathname, target: 'main' } })">Overview</a>
				{{ content | toc | safe }}
				{{ neighbours() }}
			</div>
		</div>
		
		<div class="project-col-1">
			<div class="project-header-section">
				<div class="container --project">
					<header class="project-header" id="overview">
						{% image src="cover-wide.jpg", className="project-header__img", alt="", width=920, priority="high" %}
						<div class="project-header__main-description">
							<div class="project-header__h1-row">
								<h1 class="project-header__h1">{{ title }}</h1>
							</div>
							<div class="project-header__description">{{ description }}</div>
							<div class="project-header__info-grid">
								{% if category %}
									{{ headerInfoBlock("Discipline", category | join(', ')) }}
								{% endif %}
								{% if years %}
									{{ headerInfoBlock("Timeline", years) }}
								{% endif %}
								{% for item in headerInfo | default([]) %}
									{{ headerInfoBlock(item.title, item.text) }}
								{% endfor %}
							</div>
							{{ neighbours() }}
						</div>
					</header>
				</div>
			</div>
			<div class="project-body">
				{{ content | safe }}
			</div>
				<div class="container --project">{% include "contacts-block.njk" %}</div>
		</div>
</div>